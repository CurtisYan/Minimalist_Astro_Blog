---
import { siteConfig } from '../config/site';

const { showTagline = false } = Astro.props;
const navItems = siteConfig.nav.filter((item) => !('hidden' in item && item.hidden));
---
<header class="site-header stack">
  <div class="nav-shell">
    <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="primary-nav">
      {siteConfig.menuLabel}
    </button>
    <nav class="nav" id="primary-nav" data-primary-nav aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>

  <div class="brand">
    <h1><a href="/">{siteConfig.title}</a></h1>
    {showTagline && siteConfig.description ? <p>{siteConfig.description}</p> : null}
  </div>
</header>
