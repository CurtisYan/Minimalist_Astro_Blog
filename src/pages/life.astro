---
import PostArchive from '../components/PostArchive.astro';
import SiteLayout from '../components/SiteLayout.astro';
import { siteConfig } from '../config/site';
import { filterPostsBySection, loadPosts } from '../lib/posts';

const posts = filterPostsBySection(await loadPosts(), 'life');
const section = siteConfig.sections.life;
---
<SiteLayout title={section.title}>
  <PostArchive title={section.title} posts={posts} section="life" />
</SiteLayout>
