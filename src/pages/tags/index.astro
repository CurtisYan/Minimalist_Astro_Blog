---
import SiteLayout from '../../components/SiteLayout.astro';
import { getAllTags, loadPosts } from '../../lib/posts';

const tags = getAllTags(await loadPosts());
---
<SiteLayout title="Tags">
  <main class="stack">
    <header class="archive-header">
      <h2>Tags</h2>
    </header>
    <nav class="tag-cloud" aria-label="Tags">
      {tags.map((tag) => (
        <a href={`/tags/${tag.slug}/`}>#{tag.name}<span>{tag.count}</span></a>
      ))}
    </nav>
  </main>
</SiteLayout>
